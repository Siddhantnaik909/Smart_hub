<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Smart Hub | Number Guesser</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#8b5cf6",
                        "surface": "#f8fafc",
                        "on-surface": "#0f172a",
                        "on-surface-variant": "#475569",
                        "surface-container-low": "#f1f5f9",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-high": "#e2e8f0",
                        "surface-container": "#f1f5f9",
                        "secondary-fixed": "#ede9fe",
                        "on-secondary-fixed": "#4c1d95",
                        "primary-fixed-dim": "#c4b5fd",
                        "primary-container": "#7c3aed",
                        "on-primary": "#ffffff",
                    },
                },
            },
        }
    </script>
    <style>
        :root { --primary-color: #8b5cf6; } 
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .material-symbols-outlined { font-family: 'Material Symbols Outlined'; font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; } 
        .guess-row-anim { animation: slide-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        @keyframes slide-in { 0% { transform: translateX(20px); opacity: 0; } 100% { transform: translateX(0); opacity: 0.6; } }
    </style>
</head>
<body class="bg-surface text-on-surface selection:bg-primary/20 transition-colors duration-300">
    <nav class="fixed top-0 w-full z-50 bg-slate-50/70 dark:bg-slate-900/70 backdrop-blur-xl shadow-[0px_20px_40px_rgba(139,92,246,0.06)] h-20 flex items-center px-12 tracking-tight">
        <div class="max-w-[1440px] mx-auto w-full flex justify-between items-center">
            <div class="flex items-center gap-8">
                <span id="nav-site-logo-text" class="text-xl font-bold tracking-tighter text-slate-900 text-primary uppercase">Smart Hub</span>
                <div class="hidden md:flex items-center gap-6">
                    <a class="text-slate-500 hover:text-slate-900 transition-colors" href="/index.html">Home</a>
                    <a class="text-primary font-semibold border-b-2 border-primary pb-1" href="/calculators.html">Tools</a>
                    <a class="text-slate-500 hover:text-slate-900 transition-colors" href="/GameLobby.html">Games</a>
                    <a class="text-slate-500 hover:text-slate-900 transition-colors" href="/history.html">History</a>
                    <a class="text-slate-500 hover:text-slate-900 transition-colors" href="/about.html">About</a>
                </div>
            </div>
            <div class="flex items-center gap-4" id="auth-actions">
                <!-- Populated by script.js -->
            </div>
        </div>
    </nav>

    <main class="pt-32 pb-20 min-h-screen px-12 max-w-[1440px] mx-auto">
        <div class="mb-12">
            <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-4 font-medium tracking-wide">
                <span>FUN ZONE</span>
                <span class="material-symbols-outlined text-xs">chevron_right</span>
                <span class="text-primary uppercase tracking-widest text-[10px] font-bold">Number Guessing</span>
            </nav>
            <h1 class="text-5xl font-extrabold tracking-tighter text-on-surface mb-2 font-['Plus_Jakarta_Sans']">Guess It.</h1>
            <p class="text-on-surface-variant text-lg max-w-2xl">Refined numerical isolation. Identify the hidden variable across the specified domain to achieve algorithmic resolution.</p>
        </div>

        <div class="grid grid-cols-12 gap-8 items-start">
            <!-- Sidebar -->
            <div class="col-span-12 lg:col-span-4 space-y-8">
                <div class="bg-surface-container-lowest p-8 rounded-xl shadow-[0px_20px_40px_rgba(139,92,246,0.06)]">
                    <div class="flex justify-between items-center mb-6">
                        <h3 class="text-sm font-bold tracking-[0.03em] text-on-surface uppercase text-purple-800">Match Log</h3>
                        <span onclick="clearSidebarHistory()" class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:text-primary transition-colors" title="Clear History">delete_sweep</span>
                    </div>
                    <div class="space-y-6" id="sidebar-history-container">
                        <p class="text-sm text-on-surface-variant font-medium opacity-60 text-center py-4">No recent matches.</p>
                    </div>
                </div>
            </div>

            <!-- Content Area -->
            <div class="col-span-12 lg:col-span-8">
                <div class="bg-surface-container-low rounded-3xl p-6 shadow-2xl space-y-8">
                    <!-- Display -->
                    <div class="bg-white rounded-2xl p-8 text-right flex flex-col justify-end min-h-[220px] border border-slate-100 shadow-sm relative overflow-hidden uppercase">
                        <div class="absolute top-8 left-8 flex gap-2">
                            <span class="px-3 py-1 rounded-lg bg-secondary-fixed text-on-secondary-fixed text-[10px] font-black tracking-widest uppercase" id="domain-label">DOMAIN: 1-100</span>
                            <span class="px-3 py-1 rounded-lg bg-slate-100 text-slate-600 text-[10px] font-black tracking-widest uppercase" id="game-status">AWAITING INPUT</span>
                        </div>
                        <div id="feedback-display" class="text-on-surface-variant text-xl font-medium tracking-tight mb-4 min-h-[28px]">Initial sequence ready...</div>
                        <div id="main-display" class="text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface flex items-center justify-end gap-2 overflow-hidden leading-tight">??</div>
                    </div>

                    <!-- Input Section -->
                    <div class="p-8 space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                            <div class="md:col-span-2 flex flex-col gap-2">
                                <label class="text-[9px] font-black text-on-surface-variant uppercase ml-1">Difficulty Configuration</label>
                                <select id="cpu-difficulty" onchange="resetGame()" class="bg-white border border-slate-100 rounded-xl px-6 py-4 text-sm font-black focus:ring-2 focus:ring-primary outline-none transition-all shadow-sm">
                                    <option value="easy">Easy (1-10)</option>
                                    <option value="med" selected>Medium (1-100)</option>
                                    <option value="hard">Hard (1-500)</option>
                                    <option value="master">Master (1-1000)</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[9px] font-black text-on-surface-variant uppercase ml-1 block">Your Guess</label>
                                <input type="number" id="user-guess" class="w-full bg-white border border-slate-100 rounded-xl px-6 py-4 text-2xl font-black focus:ring-2 focus:ring-primary outline-none transition-all shadow-sm">
                            </div>
                        </div>
                        <button onclick="makeGuess()" class="w-full bg-primary text-white py-5 rounded-xl font-black text-xs tracking-widest uppercase shadow-lg shadow-primary/20 hover:scale-[1.01] transition-all">Execute Comparison</button>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-8 border-t border-slate-200/50">
                            <div>
                                <h4 class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest mb-4">Isolation Path</h4>
                                <div id="guess-history-area" class="flex flex-wrap gap-2"></div>
                            </div>
                            <div class="space-y-4">
                                <div class="flex justify-between items-center text-xs font-bold">
                                    <span class="text-on-surface-variant uppercase tracking-widest">Iterative Count</span>
                                    <span id="attempt-counter" class="text-on-surface font-black text-xl">0</span>
                                </div>
                                <div class="h-2 w-full bg-slate-100 rounded-full overflow-hidden"><div id="progress-bar" class="h-full bg-primary w-0 transition-all duration-300"></div></div>
                            </div>
                        </div>

                        <div class="flex justify-end pt-6 border-t border-slate-200/50">
                            <button onclick="resetGame()" class="bg-white text-on-surface border border-slate-200 px-8 py-4 rounded-xl font-black text-[10px] tracking-widest uppercase hover:bg-slate-50 transition-all">Reload Game</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="/js/calc-utils.js"></script>
    <script>
        let targetNumber, attempts = 0, pastGuesses = [], gameWon = false, maxRange = 100;

        function resetGame() {
            const diff = document.getElementById('cpu-difficulty').value;
            maxRange = diff === 'easy' ? 10 : (diff === 'med' ? 100 : (diff === 'hard' ? 500 : 1000));
            targetNumber = Math.floor(Math.random() * maxRange) + 1;
            attempts = 0; pastGuesses = []; gameWon = false;
            document.getElementById('domain-label').innerText = `DOMAIN: 1-${maxRange}`;
            document.getElementById('feedback-display').innerText = 'Initial sequence ready...';
            document.getElementById('main-display').innerText = '??';
            document.getElementById('attempt-counter').innerText = '0';
            document.getElementById('progress-bar').style.width = '0%';
            document.getElementById('guess-history-area').innerHTML = '';
            document.getElementById('game-status').innerText = 'AWAITING INPUT';
            document.getElementById('user-guess').value = '';
        }

        function makeGuess() {
            if (gameWon) return;
            const input = document.getElementById('user-guess');
            const g = parseInt(input.value);
            if (isNaN(g)) return;
            attempts++; pastGuesses.push(g);
            input.value = '';
            
            const feedback = document.getElementById('feedback-display');
            const display = document.getElementById('main-display');
            const status = document.getElementById('game-status');

            if (g === targetNumber) {
                gameWon = true; status.innerText = 'ISOLATED'; feedback.innerText = 'Variable identified successfully.';
                display.innerText = g; saveMatch();
            } else {
                status.innerText = 'VARIATION';
                feedback.innerText = g > targetNumber ? 'Decrease value.' : 'Increase value.';
                display.innerText = g;
            }

            document.getElementById('attempt-counter').innerText = attempts;
            document.getElementById('progress-bar').style.width = Math.min((attempts / 12) * 100, 100) + "%";
            document.getElementById('guess-history-area').innerHTML = pastGuesses.map(v => `<div class="px-2 py-1 bg-slate-100 rounded text-[9px] font-bold text-slate-500">#${v}</div>`).join('');
        }

        async function saveMatch() {
            await window.saveCalcToHistory('Number Guesser', [{label: 'Range', val: `1-${maxRange}`}], [{label: 'Attempts', val: attempts}]);
            initSidebarHistory('Number Guesser', 'sidebar-history-container');
        }

        document.addEventListener('DOMContentLoaded', resetGame);
        document.getElementById('user-guess').addEventListener('keypress', (e) => { if(e.key==='Enter') makeGuess(); });
    </script>
    <script type="module" src="/js/script.js"></script>
</body>
</html>